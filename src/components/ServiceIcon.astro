---
import type { ServiceIcon } from "../data/services";

interface Props {
  icon: ServiceIcon;
  className?: string;
}

const { icon, className = "w-7 h-7 text-brand-yellow" } = Astro.props;
---

{icon === "trash" && (
  <svg viewBox="0 0 24 24" class={className} fill="currentColor"><path d="M9 3h6l1 2h4v2H4V5h4zM5 9h14l-1 12H6z"/></svg>
)}
{icon === "box" && (
  <svg viewBox="0 0 24 24" class={className} fill="currentColor"><path d="M3 7l9-4 9 4-9 4z"/><path d="M3 7v10l9 4V11z"/><path d="M21 7v10l-9 4V11z" fill-opacity="0.7"/></svg>
)}
{icon === "hammer" && (
  <svg viewBox="0 0 24 24" class={className} fill="currentColor"><path d="M14 2l8 6-3 3-3-2-9 9-3-3 9-9-2-3z"/></svg>
)}
{icon === "couch" && (
  <svg viewBox="0 0 24 24" class={className} fill="currentColor"><path d="M3 11a3 3 0 0 1 3-3h12a3 3 0 0 1 3 3v3H3z"/><path d="M2 14h20v5h-2v-2H4v2H2z"/></svg>
)}
{icon === "leaf" && (
  <svg viewBox="0 0 24 24" class={className} fill="currentColor"><path d="M17 4c-7 0-13 5-13 12 0 2 1 4 1 4s2-3 6-4c4-1 7-5 7-9 0-1 0-2-1-3z"/></svg>
)}
{icon === "home" && (
  <svg viewBox="0 0 24 24" class={className} fill="currentColor"><path d="M12 3l10 8h-3v10h-5v-6H10v6H5V11H2z"/></svg>
)}
