---

<section id="home" class="relative bg-brand-black overflow-hidden">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-20 sm:py-28 lg:py-36">
    <div class="max-w-4xl">
      <div class="skew-tag bg-brand-yellow text-brand-black mb-8">
        <span class="font-mono font-bold text-xs sm:text-sm tracking-widest flex items-center gap-2">
          <svg viewBox="0 0 24 24" class="w-4 h-4" fill="currentColor" aria-hidden="true">
            <path d="M13 2L3 14h7l-1 8 10-12h-7l1-8z" />
          </svg>
          KEEPIN' THE HOOD CLEAN
        </span>
      </div>

      <h1 class="display text-5xl sm:text-6xl lg:text-8xl text-white">
        Reclaim Your <span class="text-brand-yellow" style="-webkit-text-stroke:2px #ffd400; color:transparent;">Space</span><br />
        We Do the Heavy <span class="text-brand-yellow">Lifting.</span>
      </h1>

      <div class="mt-10 border-l-4 border-brand-yellow pl-5 max-w-2xl">
        <p class="font-mono text-base sm:text-lg leading-relaxed text-white/90">
          Founded by local barber Mou, we bring hard work and high energy to every job. From single appliances to full estate cleanouts, we're here to help you get your space back.
        </p>
      </div>

      <div class="mt-12 flex flex-wrap gap-5">
        <a href="#quote" class="btn-skew bg-brand-yellow text-brand-black text-base">
          <span>Get Free Quote</span>
        </a>
        <a href="#services" class="btn-skew border-2 border-white text-white text-base">
          <span>View Services</span>
        </a>
      </div>
    </div>
  </div>

  <div class="absolute bottom-0 left-0 right-0 h-12">
    <svg viewBox="0 0 1440 48" preserveAspectRatio="none" class="w-full h-full">
      <polygon points="0,48 1440,0 1440,48" fill="#ffffff" />
    </svg>
  </div>
</section>
