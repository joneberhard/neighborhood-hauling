---
import { services } from "../data/services";

const path = Astro.url.pathname;
const isActive = (href: string) =>
  href === "/" ? path === "/" : path === href || path.startsWith(href + "/");

const navLinks: { href: string; label: string; submenu?: typeof services }[] = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/services", label: "Services", submenu: services },
  { href: "/contact", label: "Contact" },
];
---

<header class="relative z-30 bg-brand-black border-b border-brand-yellow/40">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10">
    <div class="flex items-center justify-between py-4 gap-4">
      <a href="/" class="flex items-center gap-3 shrink-0">
        <div
          class="size-14 rounded-full bg-brand-yellow ring-2 ring-brand-yellow flex items-center justify-center"
          aria-label="Neighborhood Hauling logo"
        >
          <svg viewBox="0 0 64 40" class="w-9 h-6 text-brand-black" fill="currentColor" aria-hidden="true">
            <path d="M2 8h32v18H2z" />
            <path d="M34 14h14l8 8v4H34z" />
            <circle cx="14" cy="30" r="6" fill="#0a0a0a" />
            <circle cx="14" cy="30" r="2.5" fill="#ffd400" />
            <circle cx="46" cy="30" r="6" fill="#0a0a0a" />
            <circle cx="46" cy="30" r="2.5" fill="#ffd400" />
          </svg>
        </div>
        <span class="hidden sm:flex flex-col leading-tight">
          <span class="display text-white text-base">Neighborhood</span>
          <span class="font-mono text-[10px] tracking-[0.25em] text-brand-yellow">HAULING & JUNK REMOVAL</span>
        </span>
      </a>

      <nav class="hidden lg:flex items-center gap-10">
        {navLinks.map((link) => {
          const active = isActive(link.href);
          if (!link.submenu) {
            return (
              <a
                href={link.href}
                class:list={[
                  "font-display italic uppercase hover:text-brand-yellow transition-colors text-lg tracking-wide",
                  active ? "text-brand-yellow" : "text-white",
                ]}
              >
                {link.label}
              </a>
            );
          }
          return (
            <div class="group relative">
              <a
                href={link.href}
                aria-haspopup="true"
                class:list={[
                  "font-display italic uppercase hover:text-brand-yellow transition-colors text-lg tracking-wide flex items-center gap-1.5 py-1",
                  active ? "text-brand-yellow" : "text-white",
                ]}
              >
                {link.label}
                <svg viewBox="0 0 24 24" class="w-3.5 h-3.5 transition-transform group-hover:rotate-180 group-focus-within:rotate-180" fill="currentColor" aria-hidden="true"><path d="M6 9l6 6 6-6z"/></svg>
              </a>
              <div
                class="invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 group-focus-within:translate-y-0 transition-all duration-150 absolute top-full left-0 pt-3 w-72 z-40"
                role="menu"
              >
                <div class="bg-brand-black border-2 border-brand-yellow shadow-[8px_8px_0_0_rgba(255,212,0,0.15)]">
                  <a
                    href={link.href}
                    class="block px-5 py-3 font-mono text-[11px] tracking-widest text-brand-yellow border-b border-brand-yellow/30 hover:bg-brand-yellow hover:text-brand-black transition-colors"
                    role="menuitem"
                  >
                    ALL SERVICES &gt;&gt;
                  </a>
                  {link.submenu.map((s) => (
                    <a
                      href={`/services/${s.slug}`}
                      class:list={[
                        "block px-5 py-3 font-mono text-sm hover:bg-brand-yellow hover:text-brand-black transition-colors border-b border-white/5 last:border-0",
                        path === `/services/${s.slug}` ? "text-brand-yellow" : "text-white/90",
                      ]}
                      role="menuitem"
                    >
                      {s.title}
                    </a>
                  ))}
                </div>
              </div>
            </div>
          );
        })}
      </nav>

      <div class="flex items-center gap-3 sm:gap-4">
        <a href="tel:+18015164149" class="hidden md:flex items-center gap-2 group">
          <span class="size-9 rounded-full bg-brand-yellow flex items-center justify-center">
            <svg viewBox="0 0 24 24" class="w-4 h-4 text-brand-black" fill="currentColor" aria-hidden="true">
              <path d="M6.6 10.8a15.1 15.1 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.6 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1z" />
            </svg>
          </span>
          <span class="font-mono text-white group-hover:text-brand-yellow transition-colors">(801) 516-4149</span>
        </a>

        <a href="/contact" class="hidden sm:inline-flex btn-skew bg-brand-yellow text-brand-black text-sm sm:text-base font-bold">
          <span>Get Free Quote</span>
        </a>

        <button
          id="mobile-menu-open"
          type="button"
          class="lg:hidden size-11 flex items-center justify-center bg-brand-yellow text-brand-black hover:translate-y-[-2px] transition-transform"
          aria-label="Open menu"
          aria-controls="mobile-menu"
          aria-expanded="false"
        >
          <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor" aria-hidden="true">
            <rect x="3" y="6" width="18" height="2.5"/>
            <rect x="3" y="11" width="18" height="2.5"/>
            <rect x="3" y="16" width="18" height="2.5"/>
          </svg>
        </button>
      </div>
    </div>
  </div>
</header>

<div
  id="mobile-menu"
  class="hidden fixed inset-0 z-50 bg-brand-black overflow-y-auto lg:hidden"
  role="dialog"
  aria-modal="true"
  aria-label="Site menu"
>
  <div class="px-4 sm:px-6 py-4 border-b border-brand-yellow/40 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <div class="size-12 rounded-full bg-brand-yellow flex items-center justify-center">
        <svg viewBox="0 0 64 40" class="w-8 h-5 text-brand-black" fill="currentColor"><path d="M2 8h32v18H2z"/><path d="M34 14h14l8 8v4H34z"/><circle cx="14" cy="30" r="6" fill="#0a0a0a"/><circle cx="14" cy="30" r="2.5" fill="#ffd400"/><circle cx="46" cy="30" r="6" fill="#0a0a0a"/><circle cx="46" cy="30" r="2.5" fill="#ffd400"/></svg>
      </div>
      <span class="flex flex-col leading-tight">
        <span class="display text-white text-base">Neighborhood</span>
        <span class="font-mono text-[9px] tracking-[0.25em] text-brand-yellow">HAULING & JUNK REMOVAL</span>
      </span>
    </a>
    <button
      id="mobile-menu-close"
      type="button"
      class="size-11 flex items-center justify-center bg-brand-yellow text-brand-black hover:translate-y-[-2px] transition-transform"
      aria-label="Close menu"
    >
      <svg viewBox="0 0 24 24" class="w-6 h-6" fill="currentColor" aria-hidden="true">
        <path d="M18.3 5.71L12 12l6.3 6.3-1.42 1.41L10.59 13.4 4.29 19.7 2.88 18.29 9.17 12 2.88 5.71 4.29 4.29 10.59 10.59 16.88 4.29z"/>
      </svg>
    </button>
  </div>

  <nav class="px-4 sm:px-6 py-6">
    <a
      href="/"
      class:list={[
        "block display italic text-3xl py-3 border-b border-white/10 hover:text-brand-yellow transition-colors",
        path === "/" ? "text-brand-yellow" : "text-white",
      ]}
    >Home</a>

    <a
      href="/about"
      class:list={[
        "block display italic text-3xl py-3 border-b border-white/10 hover:text-brand-yellow transition-colors",
        isActive("/about") ? "text-brand-yellow" : "text-white",
      ]}
    >About</a>

    <div class="border-b border-white/10">
      <a
        href="/services"
        class:list={[
          "block display italic text-3xl py-3 hover:text-brand-yellow transition-colors flex items-center justify-between",
          path === "/services" ? "text-brand-yellow" : "text-white",
        ]}
      >
        Services
        <span class="font-mono text-[10px] tracking-widest text-brand-yellow">ALL &gt;</span>
      </a>
      <ul class="pb-4 pl-1 space-y-1">
        {services.map((s) => (
          <li>
            <a
              href={`/services/${s.slug}`}
              class:list={[
                "block py-2.5 pl-4 border-l-2 font-mono text-sm hover:text-brand-yellow hover:border-brand-yellow transition-colors",
                path === `/services/${s.slug}`
                  ? "text-brand-yellow border-brand-yellow"
                  : "text-white/80 border-white/20",
              ]}
            >
              {s.title}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <a
      href="/contact"
      class:list={[
        "block display italic text-3xl py-3 border-b border-white/10 hover:text-brand-yellow transition-colors",
        isActive("/contact") ? "text-brand-yellow" : "text-white",
      ]}
    >Contact</a>

    <div class="mt-8 space-y-4">
      <a href="/contact" class="btn-skew bg-brand-yellow text-brand-black text-base w-full justify-center flex">
        <span>Get Free Quote</span>
      </a>
      <a href="tel:+18015164149" class="flex items-center gap-3 px-1 py-3">
        <span class="size-10 rounded-full bg-brand-yellow flex items-center justify-center shrink-0">
          <svg viewBox="0 0 24 24" class="w-5 h-5 text-brand-black" fill="currentColor"><path d="M6.6 10.8a15.1 15.1 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.6 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1z"/></svg>
        </span>
        <span>
          <span class="font-mono text-[10px] tracking-widest text-brand-yellow block">CALL OR TEXT</span>
          <span class="font-mono text-white text-lg">(801) 516-4149</span>
        </span>
      </a>
    </div>
  </nav>
</div>

<script>
  const btnOpen = document.getElementById("mobile-menu-open");
  const btnClose = document.getElementById("mobile-menu-close");
  const menu = document.getElementById("mobile-menu");

  const setOpen = (open: boolean) => {
    if (!menu || !btnOpen) return;
    menu.classList.toggle("hidden", !open);
    document.body.classList.toggle("overflow-hidden", open);
    btnOpen.setAttribute("aria-expanded", String(open));
  };

  btnOpen?.addEventListener("click", () => setOpen(true));
  btnClose?.addEventListener("click", () => setOpen(false));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && menu && !menu.classList.contains("hidden")) {
      setOpen(false);
    }
  });
</script>
