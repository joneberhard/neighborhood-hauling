---

<section id="quote" class="bg-brand-yellow relative py-20 lg:py-24 overflow-hidden">
  <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(-45deg, #0a0a0a 0, #0a0a0a 2px, transparent 2px, transparent 28px);"></div>

  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-10 relative">
    <div class="text-center">
      <div class="skew-tag bg-brand-black text-brand-yellow mb-5">
        <span class="font-mono font-bold text-xs tracking-widest">START YOUR CLEANOUT</span>
      </div>
      <h2 class="display text-5xl sm:text-6xl lg:text-7xl text-brand-black">
        Just Point to the Junk &mdash;<br />
        <span class="text-white" style="-webkit-text-stroke:2px #0a0a0a;">Poof, It's Gone.</span>
      </h2>
      <p class="mt-6 max-w-2xl mx-auto text-brand-black/85 text-base sm:text-lg">
        No stress, no mess. Tell us what's going and we'll have a quote in your inbox before you've finished your coffee.
      </p>

      <div class="mt-10 flex flex-wrap gap-5 justify-center">
        <a href="tel:+18015164149" class="btn-skew bg-brand-black text-brand-yellow text-base">
          <span>Call (801) 516-4149</span>
        </a>
        <a href="mailto:team@neighborhoodhaulingut.com" class="btn-skew bg-white text-brand-black text-base border-2 border-brand-black">
          <span>Email Us</span>
        </a>
      </div>

      <div class="mt-12 grid sm:grid-cols-3 gap-3 max-w-3xl mx-auto">
        <div class="bg-brand-black/95 text-white p-4 text-left">
          <div class="font-mono text-[10px] tracking-widest text-brand-yellow">CALL</div>
          <div class="font-mono text-sm mt-1">(801) 516-4149</div>
        </div>
        <div class="bg-brand-black/95 text-white p-4 text-left">
          <div class="font-mono text-[10px] tracking-widest text-brand-yellow">EMAIL</div>
          <div class="font-mono text-xs mt-1 break-all">team@neighborhoodhaulingut.com</div>
        </div>
        <div class="bg-brand-black/95 text-white p-4 text-left">
          <div class="font-mono text-[10px] tracking-widest text-brand-yellow">SHOP</div>
          <div class="font-mono text-xs mt-1">564 Lewski Ln, Bluffdale UT</div>
        </div>
      </div>
    </div>
  </div>
</section>
