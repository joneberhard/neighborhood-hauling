---
const year = new Date().getFullYear();
---

<footer id="contact" class="bg-brand-black text-white border-t-4 border-brand-yellow">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-10 py-14">
    <div class="grid md:grid-cols-3 gap-10">
      <div>
        <div class="flex items-center gap-3">
          <div class="size-12 rounded-full bg-brand-yellow flex items-center justify-center">
            <svg viewBox="0 0 64 40" class="w-8 h-5 text-brand-black" fill="currentColor"><path d="M2 8h32v18H2z"/><path d="M34 14h14l8 8v4H34z"/><circle cx="14" cy="30" r="6" fill="#0a0a0a"/><circle cx="14" cy="30" r="2.5" fill="#ffd400"/><circle cx="46" cy="30" r="6" fill="#0a0a0a"/><circle cx="46" cy="30" r="2.5" fill="#ffd400"/></svg>
          </div>
          <div class="leading-tight">
            <div class="display italic text-white text-lg">Neighborhood</div>
            <div class="font-mono text-[10px] tracking-[0.25em] text-brand-yellow">HAULING & JUNK REMOVAL</div>
          </div>
        </div>
        <p class="mt-5 text-white/70 text-sm leading-relaxed max-w-xs">
          Locally owned junk removal in Bluffdale, Utah. Founded by barber Mou. Keepin' the hood clean since day one.
        </p>
      </div>

      <div>
        <h4 class="display italic text-brand-yellow text-xl mb-4">Get In Touch</h4>
        <ul class="space-y-3 text-sm">
          <li>
            <a href="tel:+18015164149" class="flex items-center gap-2 text-white hover:text-brand-yellow transition-colors">
              <svg viewBox="0 0 24 24" class="w-4 h-4 text-brand-yellow shrink-0" fill="currentColor"><path d="M6.6 10.8a15.1 15.1 0 0 0 6.6 6.6l2.2-2.2a1 1 0 0 1 1-.25 11.4 11.4 0 0 0 3.6.6 1 1 0 0 1 1 1V20a1 1 0 0 1-1 1A17 17 0 0 1 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.25.2 2.45.57 3.57a1 1 0 0 1-.25 1z"/></svg>
              (801) 516-4149
            </a>
          </li>
          <li>
            <a href="mailto:team@neighborhoodhaulingut.com" class="flex items-center gap-2 text-white hover:text-brand-yellow transition-colors break-all">
              <svg viewBox="0 0 24 24" class="w-4 h-4 text-brand-yellow shrink-0" fill="currentColor"><path d="M2 6h20v12H2z"/><path d="M2 6l10 7 10-7" fill="none" stroke="#0a0a0a" stroke-width="2"/></svg>
              team@neighborhoodhaulingut.com
            </a>
          </li>
          <li class="flex items-start gap-2 text-white/80">
            <svg viewBox="0 0 24 24" class="w-4 h-4 text-brand-yellow shrink-0 mt-0.5" fill="currentColor"><path d="M12 2a7 7 0 0 0-7 7c0 5 7 13 7 13s7-8 7-13a7 7 0 0 0-7-7zm0 9a2 2 0 1 1 0-4 2 2 0 0 1 0 4z"/></svg>
            564 Lewski Ln,<br />Bluffdale, UT 84065
          </li>
        </ul>
      </div>

      <div>
        <h4 class="display italic text-brand-yellow text-xl mb-4">Quick Links</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/services" class="text-white/80 hover:text-brand-yellow transition-colors">Services</a></li>
          <li><a href="/about" class="text-white/80 hover:text-brand-yellow transition-colors">About Mou</a></li>
          <li><a href="/contact" class="text-white/80 hover:text-brand-yellow transition-colors">Get a Quote</a></li>
          <li><a href="/contact" class="text-white/80 hover:text-brand-yellow transition-colors">Contact</a></li>
        </ul>
      </div>
    </div>

    <div class="mt-12 pt-6 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-3">
      <p class="font-mono text-xs text-white/50">&copy; {year} Neighborhood Hauling and Junk Removal. All rights reserved.</p>
      <p class="font-mono text-xs text-brand-yellow tracking-widest">KEEPIN' THE HOOD CLEAN.</p>
    </div>
  </div>
</footer>
